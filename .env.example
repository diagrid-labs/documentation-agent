GITHUB_PAT=ghp_your_token_here
OPENAI_API_KEY=sk-your_key_here
PR_NUMBER=1234
SOURCE_REPO_OWNER=dapr
SOURCE_REPO_NAME=dapr-agents
DOCS_REPO_OWNER=sicoyle
DOCS_REPO_NAME=docs
DOCS_REPO_BRANCH=v1.17   # base branch in docs repo to branch off and PR against
DOCS_CONTENT_PATH=daprdocs/content/en/your_path_here   # path within docs repo to explore for context
DRY_RUN=true   # set to true to print proposed changes without creating a PR
DAPR_GRPC_TIMEOUT_SECONDS=300 # increase gRPC timeout to 5 minutes to accommodate long-running operations in the agent
